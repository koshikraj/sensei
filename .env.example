# Copy to .env.local and fill in from your Supabase project's API settings.
# The dashboard is read-only and uses the PUBLISHABLE key (safe in the browser; RLS protects data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# NOT used by the dashboard. Only the write routines need this (server-side, bypasses RLS).
# Never expose it with a NEXT_PUBLIC_ prefix.
# SUPABASE_SECRET_KEY=
